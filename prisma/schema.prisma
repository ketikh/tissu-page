generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["website"]
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  firstName String
  lastName  String
  phone     String?
  addresses Address[]
  orders    Order[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@schema("website")
}

model Address {
  id            String  @id @default(cuid())
  firstName     String
  lastName      String
  city          String
  streetAddress String
  phone         String
  notes         String?
  isDefault     Boolean @default(false)
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("website")
}

model Order {
  // Manual order flow — no online payment is taken at submit time. Tissu
  // reaches out to confirm availability, payment method, and delivery details.
  // Lifecycle (in the `status` column):
  //   pending_confirmation → confirmed → awaiting_payment → paid
  //                        → preparing → shipped → completed → cancelled
  // Payment is always manual; `paymentMethod` carries one of:
  //   undecided | bank_transfer | cash_on_delivery
  // Extra fields (contactMethod, deliveryMethod, notes, email) live inside
  // the `shippingAddress` JSON blob so the schema stays untouched.
  id              String      @id @default(cuid())
  date            DateTime    @default(now())
  status          String      @default("pending_confirmation")
  subtotal        Float
  shipping        Float
  discount        Float
  total           Float
  paymentMethod   String      @default("undecided")
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
  shippingAddress String      // JSON: { firstName, lastName, streetAddress, city, phone, email?, contactMethod, deliveryMethod, notes? }

  @@schema("website")
}

model OrderItem {
  id          String @id @default(cuid())
  productId   String
  variantId   String
  quantity    Int
  price       Float
  productName String // JSON string
  variantName String // JSON string
  image       String
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@schema("website")
}

// Simple key/value bucket for site-wide admin settings that don't fit the
// tissu-agent CMS (which has a fixed page/section schema). E.g. per-product
// photo positions for the shop grid.
model AppSetting {
  key       String   @id
  value     String   // JSON, stringified
  updatedAt DateTime @updatedAt

  @@schema("website")
}
