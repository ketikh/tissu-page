generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["website"]
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  firstName String
  lastName  String
  phone     String?
  addresses Address[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@schema("website")
}

model Address {
  id            String  @id @default(cuid())
  firstName     String
  lastName      String
  city          String
  streetAddress String
  phone         String
  notes         String?
  isDefault     Boolean @default(false)
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("website")
}

// Simple key/value bucket for site-wide admin settings that don't fit the
// tissu-agent CMS (which has a fixed page/section schema). E.g. per-product
// photo positions for the shop grid.
model AppSetting {
  key       String   @id
  value     String   // JSON, stringified
  updatedAt DateTime @updatedAt

  @@schema("website")
}
