# ─────────────────────────────────────────────────────────────────────────────
# Tissu storefront — environment variables
# Copy this file to .env (local) and set every value in Railway for production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (customer auth + addresses) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma → Supabase pooler. URL-encode special chars in the password
# (e.g. ! must be %21). Append pgbouncer params for the transaction pooler:
#   ?pgbouncer=true&connection_limit=1
DATABASE_URL=

# ── tissu-agent admin API (products / inventory / CMS / promo) ──
# Public Railway URL of the tissu-agent FastAPI (no trailing slash).
ADMIN_API_URL=
# Tenant-scoped API key issued by tissu-agent.
ADMIN_API_KEY=
# Public storefront key — used for the public read-only endpoints the agent
# exposes (e.g. /api/storefront/necklace-options). Different from ADMIN_API_KEY.
STOREFRONT_API_KEY=

# ── Admin panel login (this app's own admin, separate from Supabase) ──
ADMIN_USERNAME=
ADMIN_PASSWORD=
# 32+ random chars — used to sign the admin session cookie. Rotating this
# value signs every admin out.
ADMIN_SESSION_SECRET=

# ── Telegram notifications (new orders ping the shop's Telegram) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional — comma-separated extra chat IDs to mirror notifications.
TELEGRAM_EXTRA_CHAT_IDS=

# ── Order confirmation copy ──
# Shown to the customer after submitting an order and on the success page.
# Plain text; line breaks are preserved.
TISSU_BANK_INFO=

# ── Public site URL (used in metadata, sitemap, email links) ──
SITE_URL=https://tissu.example.com

# ── Optional ──
# Once-used during Georgian copy generation, safe to leave blank.
GEMINI_API_KEY=
# Public REST base for the Next.js app itself (only set if you call your own
# API from a different origin — usually not needed).
NEXT_PUBLIC_API_URL=
