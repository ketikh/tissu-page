# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Tissu admin panel (tissu-agent) — storefront pulls products, prices, images from here.
# ADMIN_API_URL should be the public Railway URL of the admin panel (no trailing slash).
# ADMIN_API_KEY is a tenant-scoped key issued by the admin panel.
# If either is missing, the website falls back to built-in placeholder products.
ADMIN_API_URL=
ADMIN_API_KEY=

# Optional — Gemini (used once for Georgian copy generation, safe to leave blank)
GEMINI_API_KEY=
